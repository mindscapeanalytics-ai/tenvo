# Dashboard Consolidation Feature Flags
# 
# These flags control the gradual rollout of the unified dashboard system.
# Set to 'true' to enable, 'false' or omit to disable.

# Unified Dashboard System
# Enables consolidated dashboard with role-based templates and shared components
NEXT_PUBLIC_ENABLE_UNIFIED_DASHBOARD=false

# Role-Based Dashboard Templates
# Enables role-specific dashboard templates (Owner, Manager, Sales, Inventory, Accountant)
NEXT_PUBLIC_ENABLE_ROLE_TEMPLATES=false

# Dashboard Layout Persistence
# Enables saving and loading custom dashboard layouts
NEXT_PUBLIC_ENABLE_LAYOUT_PERSISTENCE=false

# Real-Time Dashboard Updates
# Enables WebSocket-based real-time metrics updates
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=false
