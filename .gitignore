# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
/.claude
# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# next.js
/.next/
/out/
/.kiro/
/backups/

# production
/build
/backups
/archive

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Allow a tracked, secret-free local defaults file (see .env.example).
.env.local

# local MCP/tool secrets
.vscode/mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cursor local agent state (not part of the product)
.cursor/hooks/state/

# Proprietary — do not publish root/docs README that expose product architecture or setup playbooks
/README.md
README_DASHBOARD_CHANGES.md
docs/README.md
docs/README_*.md

# maintenance & diagnostics
/_maintenance/
/reports/
*.log
*.txt
!docs/*.md
# Re-hide proprietary overview docs even if docs/*.md is allowlisted above
docs/README.md
docs/README_*.md
!package.json
!pnpm-lock.yaml
!next.config.js
!postcss.config.js
!eslint.config.mjs
!jsconfig.json
!components.json
!prisma.config.ts
!schema.prisma

# Root one-off audits, scratch SQL, and demo HTML extracts (keep under /archive locally)
/SYSTEM_AUDIT_REPORT.json
/scratch_query.js
/scratch_*.js
/check_*.sql
/fix_*.sql
/*.html
!index.html
