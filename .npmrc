# App keeps zod@3 (AI SDK + app schemas). better-auth nests zod@4.
# better-call's peerOptional zod@^4 cannot be satisfied at the root without a
# Zod 4 migration; postinstall nests zod@4 under better-call for runtime.
# legacy-peer-deps avoids install-time ERESOLVE noise for that intentional split.
legacy-peer-deps=true
